<%- include('../partials/header') %>

<main class="container py-5 flex-grow-1">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="card p-4 p-sm-5 border-0 shadow bg-body-tertiary rounded-4 position-relative overflow-hidden">

                <div class="text-center mb-4 border-bottom pb-4 border-secondary-subtle">
                    <h2 class="fw-bold text-uppercase tracking-wider mt-2 mb-1 fs-3">Recibo de Compra</h2>
                    <p class="text-muted small mb-0">Cliente: <strong class="text-body"><%= cliente %></strong></p>
                </div>

                <div class="mb-4 border-bottom pb-3 border-secondary-subtle">
                    <h5 class="fw-bold text-uppercase small text-muted tracking-wider mb-3">Detalle del Pedido</h5>

                    <div class="d-flex justify-content-between align-items-center mb-3 placeholder-glow" aria-hidden="true">
                        <div class="w-70">
                            <span class="placeholder col-8 rounded fs-5 d-block mb-1"></span>
                            <span class="placeholder col-3 rounded small"></span>
                        </div>
                        <span class="placeholder col-2 rounded fs-5"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3 placeholder-glow" aria-hidden="true">
                        <div class="w-70">
                            <span class="placeholder col-5 rounded fs-5 d-block mb-1"></span>
                            <span class="placeholder col-2 rounded small"></span>
                        </div>
                        <span class="placeholder col-3 rounded fs-5"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3 placeholder-glow" aria-hidden="true">
                        <div class="w-70">
                            <span class="placeholder col-9 rounded fs-5 d-block mb-1"></span>
                            <span class="placeholder col-4 rounded small"></span>
                        </div>
                        <span class="placeholder col-2 rounded fs-5"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-5">
                    <span class="fw-bold text-uppercase tracking-wider text-muted small">Total Pagado</span>
                    <span class="fw-bold fs-2 text-success">
                        <span class="placeholder-glow" aria-hidden="true"><span class="placeholder col-4 rounded d-inline-block" style="width: 80px; height: 35px;"></span></span>$
                    </span>
                </div>

                <div class="row g-2">
                    <div class="col-12 col-sm-6">
                        <button type="button" class="btn btn-primary w-100 py-2.5 fw-bold text-uppercase d-flex align-items-center justify-content-center gap-2 rounded-3">
                            Descargar
                        </button>
                    </div>
                    <div class="col-12 col-sm-6">
                        <a href="/" class="btn btn-outline-secondary w-100 py-2.5 fw-bold text-uppercase d-flex align-items-center justify-content-center gap-2 rounded-3">
                            Inicio
                        </a>
                    </div>
                </div>

            </div>

        </div>
    </div>
</main>

<%- include('../partials/footer') %>