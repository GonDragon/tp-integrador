<%- include('../partials/header') %>

<main class="container d-flex flex-column align-items-center justify-content-center flex-grow-1 py-5">
    <div class="card p-4 p-md-5 shadow text-center border-0 bg-body-tertiary" style="max-width: 550px; width: 100%;">

        <h1 class="fw-bold mb-3 text-uppercase fs-2 tracking-wide">
            ¡Bienvenido!
        </h1>
        <p class="fs-6 text-muted mb-4">
            Esta es tu plataforma digital para el pedido y alquiler de productos, servicios y maquinaria pesada dentro de las instalaciones de <strong>ColisseumFit</strong>.
        </p>

        <form action="/catalogo" method="GET" class="text-start">
            <div class="mb-4">
                <label for="nombre" class="form-label fw-semibold small text-uppercase">
                    Tu Nombre
                </label>
                <input
                        type="text"
                        id="nombre"
                        name="nombre"
                        class="form-control form-control-lg"
                        required
                />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg fw-bold text-uppercase">
                    Continuar
                </button>
            </div>
        </form>

    </div>
</main>

<%- include('../partials/footer') %>