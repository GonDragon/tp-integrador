<%- include('../partials/header') %>

<div class="container" style="margin-top: -3.5rem; position: relative; z-index: 10;">
    <div class="row g-2 flex-nowrap justify-content-center">

        <div class="col-3" style="max-width: 115px;">
            <a type="button" href="/" class="btn btn-outline-secondary bg-body shadow-sm w-100 d-flex flex-column align-items-center justify-content-center rounded-3 p-2" style="aspect-ratio: 1 / 1;">
                <span class="fs-3">⬅️</span>
                <span class="fw-bold mt-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">Volver</span>
            </a>
        </div>

        <div class="col-3" style="max-width: 115px;">
            <button type="button" class="btn btn-outline-secondary bg-body shadow-sm w-100 d-flex flex-column align-items-center justify-content-center rounded-3 p-2" style="aspect-ratio: 1 / 1;">
                <span class="fs-3">📦</span>
                <span class="fw-bold mt-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">Cat 1</span>
            </button>
        </div>

        <div class="col-3" style="max-width: 115px;">
            <button type="button" class="btn btn-outline-secondary bg-body shadow-sm w-100 d-flex flex-column align-items-center justify-content-center rounded-3 p-2" style="aspect-ratio: 1 / 1;">
                <span class="fs-3">🏋️</span>
                <span class="fw-bold mt-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">Cat 2</span>
            </button>
        </div>

        <div class="col-3" style="max-width: 115px;">
            <a type="button" href="/carrito" class="btn btn-outline-secondary bg-body shadow-sm w-100 d-flex flex-column align-items-center justify-content-center rounded-3 p-2" style="aspect-ratio: 1 / 1;">
                <span class="fs-3">➡️</span>
                <span class="fw-bold mt-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">Carrito</span>
            </a>
        </div>

    </div>
</div>

<main class="container py-4 text-center">
    <h2 class="fw-bold text-uppercase tracking-wider mb-1">Catálogo</h2>
    <p class="text-muted small">Bienvenido de vuelta, <strong><%= cliente %></strong></p>

    <div class="row g-4 mt-4">
        <% if (productos && productos.length > 0) { %>
            <% productos.forEach(producto => { %>
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm bg-body-tertiary text-start">
                        
                        <img src="/img/<%= producto.imagen %>" class="card-img-top p-3" alt="<%= producto.nombre %>" style="height: 200px; object-fit: contain;">
                        
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold mb-2"><%= producto.nombre %></h5>
                            
                            <p class="card-text flex-grow-1 mb-3 small text-muted"><%= producto.descripcion %></p>
                            
                            <div class="mb-3">
                                <span class="fs-5 fw-bold">$<%= producto.precio %></span>
                            </div>
                            
                            <div class="mt-auto">
                                <button class="btn btn-primary fw-bold w-100 rounded-2 text-uppercase btn-agregar" 
                                        data-id="<%= producto.id %>" 
                                        data-nombre="<%= producto.nombre %>" 
                                        data-precio="<%= producto.precio %>">
                                    Agregar al carrito
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center mt-5">
                <h4 class="text-muted">Todavía no hay productos cargados en el catálogo.</h4>
            </div>
        <% } %>
    </div>
</main>

<!-- Conexión con el cerebro del carrito -->
<script src="/js/catalogo.js"></script>

<%- include('../partials/footer') %>