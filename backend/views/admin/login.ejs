<%- include('../partials/header') %>

<main class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card p-5 border-0 shadow-lg bg-body-tertiary rounded-4 w-100" style="max-width: 450px;">
        
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle shadow-sm" style="width: 70px; height: 70px; margin-bottom: 1rem;">
                <span class="fs-2">🔒</span>
            </div>
            <h2 class="fw-bold text-uppercase tracking-wider fs-3">Acceso Admin</h2>
            <p class="text-muted small">Ingresá tus credenciales para gestionar el stock.</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger fw-bold text-center small rounded-3 border-0 shadow-sm" role="alert">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST">
            
            <button type="button" class="btn btn-outline-info btn-sm w-100 mb-4 fw-bold d-flex align-items-center justify-content-center gap-2 rounded-3" onclick="document.getElementById('usuario').value = 'admin'; document.getElementById('password').value = 'admin';">
                <span>⚡</span> Autocompletar datos de prueba
            </button>

            <div class="mb-3">
                <label for="usuario" class="form-label fw-bold small text-muted text-uppercase">Usuario</label>
                <input type="text" class="form-control form-control-lg bg-body border-0 shadow-sm" id="usuario" name="usuario" placeholder="Ej: admin" required autofocus>
            </div>
            
            <div class="mb-4">
                <label for="password" class="form-label fw-bold small text-muted text-uppercase">Contraseña</label>
                <input type="password" class="form-control form-control-lg bg-body border-0 shadow-sm" id="password" name="password" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold text-uppercase shadow-sm rounded-3">
                Entrar al Panel
            </button>
        </form>

        <div class="text-center mt-4">
            <a href="/" class="text-decoration-none text-muted small hover-primary">
                ⬅️ Volver al inicio
            </a>
        </div>

    </div>
</main>

<%- include('../partials/footer') %>