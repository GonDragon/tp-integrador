<%- include('../partials/header') %>

<main class="container py-5 flex-grow-1">
    
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/admin" class="btn btn-outline-secondary d-flex align-items-center justify-content-center p-2 rounded-3">
            <span>⬅️</span>
        </a>
        <div>
            <h2 class="fw-bold text-uppercase tracking-wider m-0 fs-3">Nuevo Producto</h2>
            <p class="text-muted small mb-0">Completá los datos para agregarlo al catálogo público.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card p-4 p-md-5 border-0 shadow-sm bg-body-tertiary rounded-4">
                
                <% if (error) { %>
                    <div class="alert alert-danger fw-bold text-center small rounded-3 mb-4 border-0 shadow-sm">
                        ⚠️ <%= error %>
                    </div>
                <% } %>

                <form action="/admin/productos/nuevo" method="POST" enctype="multipart/form-data">
                    
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-5">
                            <label for="nombre" class="form-label fw-bold small text-muted text-uppercase">Nombre del Producto</label>
                            <input type="text" class="form-control form-control-lg border-0 shadow-sm" id="nombre" name="nombre" placeholder="Ej: Proteína Whey Premium" required autofocus>
                        </div>
                        <div class="col-12 col-md-4">
                            <label for="precio" class="form-label fw-bold small text-muted text-uppercase">Precio ($)</label>
                            <input type="number" step="0.01" class="form-control form-control-lg border-0 shadow-sm text-success fw-bold" id="precio" name="precio" placeholder="18500" required>
                        </div>
                        <div class="col-12 col-md-3">
                            <label for="stock" class="form-label fw-bold small text-muted text-uppercase">Stock</label>
                            <input type="number" class="form-control form-control-lg border-0 shadow-sm fw-bold" id="stock" name="stock" value="10" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="detalles" class="form-label fw-bold small text-muted text-uppercase">Detalles / Descripción</label>
                        <textarea class="form-control border-0 shadow-sm" id="detalles" name="detalles" rows="3" placeholder="Breve descripción del suplemento o producto..." required></textarea>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-6">
                            <label for="categoria" class="form-label fw-bold small text-muted text-uppercase">Categoría</label>
                            <select class="form-select border-0 shadow-sm" id="categoria" name="categoria" required>
                                <option value="" selected disabled>Seleccione una categoría</option>
                                <option value="suplementos">Suplementos</option>
                                <option value="servicios">Servicios</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="imagen" class="form-label fw-bold small text-muted text-uppercase">Imagen del Producto</label>
                            <input type="file" class="form-control border-0 shadow-sm" id="imagen" name="imagen" accept="image/*" required>
                            <div class="form-text small mt-1">Seleccioná una imagen para el producto.</div>
                        </div>
                    </div>

                    <div class="mb-4 form-check form-switch fs-5">
                        <input class="form-check-input shadow-sm" type="checkbox" role="switch" id="activo" name="activo" checked>
                        <label class="form-check-label fw-bold text-success fs-6 ms-2" for="activo" style="margin-top: 3px;">
                            Producto Activo (Visible en el catálogo)
                        </label>
                    </div>

                    <hr class="border-secondary-subtle mb-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/admin" class="btn btn-outline-secondary fw-bold px-4 py-2 rounded-3 text-uppercase">Cancelar</a>
                        <button type="submit" class="btn btn-success fw-bold px-5 py-2 rounded-3 text-uppercase shadow-sm d-flex align-items-center gap-2">
                            <span>💾</span> Guardar Producto
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>

</main>

<%- include('../partials/footer') %>